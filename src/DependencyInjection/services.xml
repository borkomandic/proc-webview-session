<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>

        <service id="ProCoders\WebViewCustomerSession\Service\HttpResponseService" public="true"/>

        <service id="ProCoders\WebViewCustomerSession\Service\SalesChannelService" public="true">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="sales_channel.repository"/>
            <argument type="service" id="Shopware\Core\System\SalesChannel\Context\CachedSalesChannelContextFactory"/>
        </service>

        <service id="ProCoders\WebViewCustomerSession\Service\CustomerPostCreatedService" public="true"/>

        <service id="ProCoders\WebViewCustomerSession\Service\CustomerService" public="true">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopware\Core\Checkout\Customer\SalesChannel\AccountService"/>
            <argument type="service" id="Symfony\Component\HttpFoundation\RequestStack"/>
            <argument type="service" id="customer.repository"/>
            <argument type="service" id="language.repository"/>
            <argument type="service" id="ProCoders\WebViewCustomerSession\Service\SalesChannelService"/>
            <argument type="service" id="ProCoders\WebViewCustomerSession\Service\CustomerPostCreatedService"/>
        </service>

        <service id="ProCoders\WebViewCustomerSession\Service\CompanyService" public="true">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="customer_group.repository"/>
            <argument type="service" id="Symfony\Contracts\EventDispatcher\EventDispatcherInterface"/>
            <argument type="service" id="ProCoders\WebViewCustomerSession\Service\SalesChannelService"/>
        </service>

    </services>
</container>
